# Admissions integration mode: mock | real
NEXT_PUBLIC_ADMISSIONS_API_MODE=mock

# ── API Gateway ──────────────────────────────────────────────────────
# Single gateway URL shared by all backend services.
# Service prefixes (/api/v1/admission-service, /api/v1/otp-service, etc.)
# are appended automatically.
NEXT_PUBLIC_API_GATEWAY_URL=http://10.10.10.200:32118
# Server-side only (not exposed to browser):
API_GATEWAY_URL=http://10.10.10.200:32118

# ── Per-service overrides (optional, for local dev) ──────────────────
# Uncomment to point individual services to different hosts/ports.
# NEXT_PUBLIC_ADMISSION_SERVICE_URL=http://localhost:8080/api/v1/admission-service
# NEXT_PUBLIC_OTP_SERVICE_URL=http://localhost:8081/api/v1/otp-service
# NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:8082/api/v1/auth-service
# NEXT_PUBLIC_NOTIFICATION_SERVICE_URL=http://localhost:8083/api/email/v1

# ── Legacy (backwards compat, used if gateway vars are not set) ──────
ADMISSIONS_API_BASE_URL=http://10.10.10.200:32118
NEXT_PUBLIC_ADMISSIONS_API_BASE_URL=http://10.10.10.200:32118
